# ── PRIMARY: OpenRouter (recommended — no rate limits) ────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
# Model to use (change to any model you prefer)
# Recommended: google/gemini-2.5-flash, deepseek/deepseek-r1, anthropic/claude-sonnet-4
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── FALLBACK: Gemini Direct (FREE but rate-limited) ──────────────────────────
# Get your FREE Gemini key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# Leave blank — Google News RSS is used as fallback (also free)
# NEWS_API_KEY=
